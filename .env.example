# Conexão direta ao Postgres do projeto Supabase. Pegue em
# Project Settings → Database → Connection string → URI.
# Use a DSN "Session" (não "Pooler") em runs longos.
SUPABASE_DB_URL="postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres"

# HMAC pepper para core.hash_cpf — gere com `openssl rand -hex 32`.
# NUNCA commitar; injetar via fly secrets / GitHub Actions secrets.
CPF_PEPPER=""

# Quantos tenants SOLEON crawlear por run (1..116, ou "all").
SOLEON_SITES=5
