# Dados grandes que não vão pra imagem
data/raw/
data/processed/
data/intermediate/cache/
data/intermediate/auctioneers_*.csv
data/intermediate/site_analysis.csv

# specs internas — só queremos _providers/<provider>/selectors.yaml.
# BuildKit interpreta `[!_]*` ERRADO (exclui `_providers` apesar do `_`).
# Solução: exclui specs/ inteiro e reinclui _providers via negation.
specs/
!specs/_providers/
!specs/_providers/**
# Re-exclui arquivos pesados/transientes dentro de _providers/
specs/_providers/_status.md
specs/_providers/*/pilot_*.html
specs/_providers/*/pilot_xhr*.har*
specs/_providers/*/_*.json
specs/_providers/*/_*.html

# Reports e docs
reports/
docs/

